# Polski B1 Coach — приклад конфігу. Скопіюй у .env на сервері й заповни.
# .env у git НЕ потрапляє (див. .gitignore).

# Токен бота від @BotFather (ОБОВʼЯЗКОВО)
BOT_TOKEN=

# Ключ Anthropic API для генерації уроків і фідбеку (опційно, але рекомендовано)
ANTHROPIC_API_KEY=

# Адмін (Telegram user id — єдиний адмін для схвалення доступу)
ADMIN_ID=

# Redis (за замовчуванням — сервіс redis у docker compose)
REDIS_URL=redis://redis:6379/0

# PostgreSQL. Задай СИЛЬНИЙ пароль (не лишай дефолтний polski/polski).
# POSTGRES_PASSWORD використовує сервіс postgres; DATABASE_URL — застосунок.
POSTGRES_PASSWORD=
# DATABASE_URL=postgresql+asyncpg://polski:<той_самий_пароль>@postgres:5432/polski

# Sentry — трекінг помилок (опційно; лиши порожнім, щоб вимкнути)
SENTRY_DSN=

# Часовий пояс і година щоденного нагадування
TIMEZONE=Europe/Warsaw
LESSON_HOUR=8

# Дата цільового іспиту (для лічильника днів)
EXAM_DATE=2026-12-05
